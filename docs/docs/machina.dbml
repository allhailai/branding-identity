// ============================================================================
// SCHEDULING & APPOINTMENTS
// ============================================================================

Table appointments {
  id bigint [pk]
  org_id bigint [not null, ref: > orgs.id]
  contact_id bigint [ref: > contacts.id]
  patient_id bigint [ref: > patients.id]
  appointment_series_id bigint [ref: > appointment_series.id]
  contact_address_id bigint [ref: > contact_addresses.id]
  contact_phone_id bigint [ref: > contact_phone_numbers.id]
  status_key string [ref: > appointments_lku_statuses.key]
  type_key string [ref: > visit_lku_types.key]
  modality_key string [ref: > visit_lku_modalities.key]
  cancellation_reason_key string [ref: > appointments_lku_cancellation_reasons.key]
  scheduled_start_at timestamp
  scheduled_end_at timestamp
  cancelled_at timestamp
  description string
  join_url string
  note_human string
  note_ai string
  note_system string
  cancellation_notes string
  ext jsonb
  is_busy boolean
  is_deleted boolean
  deleted_at timestamp
  is_series_override boolean
  is_all_day_appointment boolean
  cancelled_by_id bigint [ref: > users.id]
  deleted_by_id bigint [ref: > users.id]
  created_by_id bigint [ref: > users.id]
  updated_by_id bigint [ref: > users.id]
  created_at timestamp
  updated_at timestamp
}

Table appointments_lku_statuses {
  key string [pk]
  org_id bigint [pk, ref: > orgs.id]
  name string
  created_at timestamp
  updated_at timestamp
}

Table appointments_lku_cancellation_reasons {
  key string [pk]
  org_id bigint [pk, ref: > orgs.id]
  name string
  created_at timestamp
  updated_at timestamp
}

Table visit_lku_types {
  key string [pk]
  org_id bigint [pk, ref: > orgs.id]
  name string
  created_at timestamp
  updated_at timestamp
}

Table visit_lku_modalities {
  key string [pk]
  org_id bigint [pk, ref: > orgs.id]
  name string
  created_at timestamp
  updated_at timestamp
}

Table visit_lku_dispositions {
  key string [pk]
  org_id bigint [pk, ref: > orgs.id]
  name string
  created_at timestamp
  updated_at timestamp
}

Table appointment_series {
  id bigint [pk]
  org_id bigint [not null, ref: > orgs.id]
  contact_id bigint [ref: > contacts.id]
  patient_id bigint [ref: > patients.id]
