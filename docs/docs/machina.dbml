}

Table contact_address_lku_verification_statuses {
  key string [pk]
  org_id bigint [pk, ref: > orgs.id]
  name string
  created_at timestamp
  updated_at timestamp
}

Table contact_phone_numbers {
  id bigint [pk]
  org_id bigint [not null, ref: > orgs.id]
  contact_id bigint [not null, ref: > contacts.id]
  phone_number string
  phone_ext string
  is_primary boolean
  type_key string [ref: > contact_phone_lku_types.key]
  status_key string [ref: > contact_phone_lku_verification_statuses.key]
  is_deleted boolean
  created_by_id bigint [ref: > users.id]
  updated_by_id bigint [ref: > users.id]
  created_at timestamp
