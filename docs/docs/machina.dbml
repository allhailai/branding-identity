}

Table appointment_participant_lku_participation_statuses {
  key string [pk]
  org_id bigint [pk, ref: > orgs.id]
  name string
  created_at timestamp
  updated_at timestamp
}

Table appointment_series_participants {
  id bigint [pk]
  org_id bigint [not null, ref: > orgs.id]
  appointment_series_id bigint [not null, ref: > appointment_series.id]
  contact_id bigint [ref: > contacts.id]
  is_host boolean
  created_at timestamp
  updated_at timestamp
}

Table appointment_logical_participants {
  id bigint [pk]
