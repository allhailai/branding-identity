Table appointment_status_periods {
  id bigint [pk]
  org_id bigint [not null, ref: > orgs.id]
  appointment_id bigint [not null, ref: > appointments.id]
  status_key string [ref: > appointments_lku_statuses.key]
  start_why string
  created_at timestamp
  updated_at timestamp
}

Table visits {
  id bigint [pk]
  org_id bigint [not null, ref: > orgs.id]
