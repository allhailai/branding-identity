}

Table patient_consent_lku_types {
  key string [pk]
  org_id bigint [pk, ref: > orgs.id]
  name string
  created_at timestamp
  updated_at timestamp
}

Table patient_documents {
  id bigint [pk]
  org_id bigint [not null, ref: > orgs.id]
  patient_id bigint [not null, ref: > patients.id]
