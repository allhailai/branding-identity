// ============================================================================
// PATIENTS & CLINICAL DATA
// ============================================================================

Table patients {
  id bigint [pk]
  org_id bigint [not null, ref: > orgs.id]
  contact_id bigint [ref: > contacts.id]
  care_team_id bigint [ref: > teams.id]
  enterprise_patient_id integer
  internal_emr_id integer
  ext jsonb
  deleted_at timestamp
  is_deleted boolean
  deleted_by_id bigint [ref: > users.id]
  created_by_id bigint [ref: > users.id]
  updated_by_id bigint [ref: > users.id]
  created_at timestamp
  updated_at timestamp
}

Table patient_identifiers {
  id bigint [pk]
  org_id bigint [not null, ref: > orgs.id]
  patient_id bigint [not null, ref: > patients.id]
  identifier string
  type_key string [ref: > patient_identifier_lku_types.key]
  source_id bigint [ref: > patient_identifier_sources.id]
  created_at timestamp
  updated_at timestamp
}

Table patient_identifier_lku_types {
  key string [pk]
  org_id bigint [pk, ref: > orgs.id]
  name string
  created_at timestamp
  updated_at timestamp
}

Table patient_identifier_lku_sources {
  key string [pk]
  org_id bigint [pk, ref: > orgs.id]
  name string
  created_at timestamp
  updated_at timestamp
}

Table patient_identifier_sources {
  id bigint [pk]
  org_id bigint [not null, ref: > orgs.id]
  source_name string
  created_at timestamp
  updated_at timestamp
}

Table patient_attributes {
  id bigint [pk]
  org_id bigint [not null, ref: > orgs.id]
  patient_id bigint [not null, ref: > patients.id]
  type_key string [ref: > patient_attribute_lku_types.key]
  value string
  created_at timestamp
  updated_at timestamp
}

Table patient_attribute_lku_types {
  key string [pk]
  org_id bigint [pk, ref: > orgs.id]
  name string
  created_at timestamp
  updated_at timestamp
}

Table patient_payer_market_periods {
  id bigint [pk]
  org_id bigint [not null, ref: > orgs.id]
  patient_id bigint [not null, ref: > patients.id]
  payer_market_id bigint [ref: > payer_markets.id]
  start_at timestamp
  end_at timestamp
  created_at timestamp
  updated_at timestamp
}

Table patient_consents {
