// ============================================================================
// FIRSTHAND-SPECIFIC TABLES (FH Schema)
// ============================================================================

Table individuals {
  id bigint [pk]
  patient_id bigint [not null, ref: > patients.id]
  is_bensup_eligible boolean
  deleted_at timestamp
  is_deleted boolean
  deleted_by_id bigint [ref: > users.id]
  created_by_id bigint [ref: > users.id]
  updated_by_id bigint [ref: > users.id]
  created_at timestamp
  updated_at timestamp
}

Table nme_assessments {
  id bigint [pk]
  patient_id bigint [not null, ref: > patients.id]
  org_id bigint [not null, ref: > orgs.id]
  workflow_task_id bigint [ref: > workflow_tasks.id]
  is_currently_receiving_benefits boolean
  current_benefits_amount decimal
  approval_date date
  has_previously_applied_for_benefits string
  previous_application_result string
  has_first_decision_or_consideration_date boolean
  is_initially_approved boolean
  initial_approval_date date
  appeal_for_reconsideration_date date
  appeal_court_hearing_date date
  is_final_decision_approved boolean
  final_decision_date date
  condition_prevents_working boolean
  condition_prevents_working_since_date date
  condition_prevents_working_details string
  has_worked_consistently_in_past boolean
  has_worked_consistently_in_past_details string
  monthly_work_income decimal
  monthly_work_income_details string
  financial_help_outside_work decimal
  financial_help_outside_work_details string
  asset_value decimal
  asset_value_details string
  is_individual_interested_in_help boolean
  current_representative_name string
  current_representative_contact_info string
  is_submitted boolean
  submitted_at timestamp
  is_deleted boolean
  deleted_at timestamp
  deleted_by_id bigint [ref: > users.id]
  created_by_id bigint [ref: > users.id]
  updated_by_id bigint [ref: > users.id]
  created_at timestamp
  updated_at timestamp
}

Table expenses {
  id bigint [pk]
  patient_id bigint [not null, ref: > patients.id]
  org_id bigint [not null, ref: > orgs.id]
  amount decimal [not null]
  purchase_date date [not null]
  item_name string [not null]
  category_key string [not null, ref: > expenses_lku_categories.key]
  deleted_at timestamp
  is_deleted boolean
  deleted_by_id bigint [ref: > users.id]
  created_by_id bigint [ref: > users.id]
  updated_by_id bigint [ref: > users.id]
  created_at timestamp
  updated_at timestamp
}

Table expenses_lku_categories {
  key string [pk]
  org_id bigint [pk, ref: > orgs.id]
  name string
  created_at timestamp
  updated_at timestamp
}

Table health_checks {
  id bigint [pk]
  patient_id bigint [not null, ref: > patients.id]
