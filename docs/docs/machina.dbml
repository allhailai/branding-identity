  created_at timestamp
  updated_at timestamp
}

Table patient_document_lku_types {
  key string [pk]
  org_id bigint [pk, ref: > orgs.id]
  name string
  created_at timestamp
  updated_at timestamp
}

Table patient_bulletins {
  id bigint [pk]
  org_id bigint [not null, ref: > orgs.id]
  patient_id bigint [not null, ref: > patients.id]
