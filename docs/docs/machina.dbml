  status_key string [ref: > workflow_event_lku_statuses.key]
  event_at timestamp
  created_by_id bigint [ref: > users.id]
  updated_by_id bigint [ref: > users.id]
  created_at timestamp
  updated_at timestamp
}

Table workflow_event_lku_types {
  key string [pk]
  org_id bigint [pk, ref: > orgs.id]
