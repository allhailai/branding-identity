// Firsthand Helping Hand Database Schema
// Generated from Phoenix Ecto schemas
// Database: PostgreSQL with multi-tenant architecture (org_id scoping)

// ============================================================================
// CORE DOMAIN - Organizations & Users
// ============================================================================

Table orgs {
  id bigint [pk]
  name string [not null]
  is_deleted boolean
  org_parent_id bigint [ref: > org_parents.id]
  created_at timestamp
  updated_at timestamp
}

Table org_parents {
  id bigint [pk]
  name string [not null]
  created_at timestamp
  updated_at timestamp
}

Table users {
  id bigint [pk]
  email string
  mobile_phone string
  first_name string
  last_name string
  full_name string
  auth0_id string
  timezone_key string [ref: > ref_timezones.key]
  created_by_id bigint [ref: > users.id]
  updated_by_id bigint [ref: > users.id]
  deleted_by_id bigint [ref: > users.id]
  is_deleted boolean
  deleted_at timestamp
  created_at timestamp
  updated_at timestamp
}

Table ref_timezones {
  key string [pk]
  name string
  created_at timestamp
  updated_at timestamp
}

Table org_users {
  id bigint [pk]
  org_id bigint [not null, ref: > orgs.id]
  user_id bigint [not null, ref: > users.id]
  is_deleted boolean
  created_at timestamp
  updated_at timestamp
}

Table user_offices {
  id bigint [pk]
  user_id bigint [not null, ref: > users.id]
  office_id bigint [not null, ref: > offices.id]
  is_deleted boolean
  created_at timestamp
  updated_at timestamp
}

Table user_business_role_lku_types {
  key string [pk]
  org_id bigint [pk, ref: > orgs.id]
  name string
  created_at timestamp
  updated_at timestamp
}

Table user_business_role_periods {
  id bigint [pk]
  org_id bigint [not null, ref: > orgs.id]
  user_id bigint [not null, ref: > users.id]
  business_role_key string [ref: > user_business_role_lku_types.key]
  start_at timestamp
  end_at timestamp
  created_at timestamp
  updated_at timestamp
}

Table user_tags {
  id bigint [pk]
  org_id bigint [not null, ref: > orgs.id]
  user_id bigint [not null, ref: > users.id]
  tag_value_key string [ref: > user_tag_values.key]
  is_deleted boolean
  created_at timestamp
  updated_at timestamp
}

Table user_tag_values {
  key string [pk]
  org_id bigint [pk, ref: > orgs.id]
  display_text string
  created_at timestamp
  updated_at timestamp
}

// ============================================================================
// AUTHORIZATION & PERMISSIONS
// ============================================================================

Table authz_roles {
  key string [pk]
  org_id bigint [pk, ref: > orgs.id]
  name string
  description string
  default_route string
  is_external_role boolean
  created_by_id bigint [ref: > users.id]
  updated_by_id bigint [ref: > users.id]
  created_at timestamp
  updated_at timestamp
}

Table authz_user_roles {
  user_id bigint [pk, ref: > users.id]
  role_key string [pk, ref: > authz_roles.key]
  org_id bigint [pk, ref: > orgs.id]
  created_at timestamp
  updated_at timestamp
}

Table authz_permissions {
  key string [pk]
  org_id bigint [pk, ref: > orgs.id]
  asset_key string
  action_key string
  is_deleted boolean
  created_at timestamp
  updated_at timestamp
}

Table authz_role_permissions {
  id bigint [pk]
  org_id bigint [not null, ref: > orgs.id]
  role_key string [ref: > authz_roles.key]
  permission_key string [ref: > authz_permissions.key]
  created_at timestamp
  updated_at timestamp
}

Table authz_action_lku_types {
  key string [pk]
  created_at timestamp
  updated_at timestamp
}

Table authz_asset_lku_types {
  key string [pk]
  org_id bigint [pk, ref: > orgs.id]
  created_at timestamp
  updated_at timestamp
}

Table impersonation_logs {
  id bigint [pk]
  org_id bigint [not null, ref: > orgs.id]
  impersonator_id bigint [ref: > users.id]
  impersonated_user_id bigint [ref: > users.id]
  created_at timestamp
  updated_at timestamp
}

Table request_logs {
  id bigint [pk]
  org_id bigint [not null, ref: > orgs.id]
  user_id bigint [ref: > users.id]
  method string
  path string
  status_code integer
  created_at timestamp
  updated_at timestamp
}

Table refresh_token_whitelist {
  token string [pk]
  created_at timestamp
  updated_at timestamp
}

// ============================================================================
// TEAMS & ORGANIZATIONAL STRUCTURE
// ============================================================================

Table teams {
  id bigint [pk]
  org_id bigint [not null, ref: > orgs.id]
  name string
  team_type_key string [ref: > team_lku_types.key]
  office_id bigint [ref: > offices.id]
  ext jsonb
  is_deleted boolean
  deleted_at timestamp
  deleted_by_id bigint [ref: > users.id]
  created_by_id bigint [ref: > users.id]
  updated_by_id bigint [ref: > users.id]
  created_at timestamp
  updated_at timestamp
}

Table team_lku_types {
  key string [pk]
  org_id bigint [pk, ref: > orgs.id]
  name string
  description string
  is_deleted boolean
  deleted_at timestamp
  created_at timestamp
  updated_at timestamp
}

Table team_members {
  id bigint [pk]
  org_id bigint [not null, ref: > orgs.id]
  team_id bigint [not null, ref: > teams.id]
  user_id bigint [not null, ref: > users.id]
  ext jsonb
  created_at timestamp
  updated_at timestamp
}

Table team_member_periods {
  id bigint [pk]
  org_id bigint [not null, ref: > orgs.id]
  team_member_id bigint [not null, ref: > team_members.id]
  start_at timestamp
  end_at timestamp
  created_at timestamp
  updated_at timestamp
}

Table offices {
  id bigint [pk]
  org_id bigint [not null, ref: > orgs.id]
  region_id bigint [ref: > regions.id]
  name string
  created_at timestamp
  updated_at timestamp
}

Table regions {
  id bigint [pk]
  org_id bigint [not null, ref: > orgs.id]
  name string
  created_at timestamp
  updated_at timestamp
}

Table team_type_cfg_business_roles {
  id bigint [pk]
  org_id bigint [not null, ref: > orgs.id]
  team_type_key string [ref: > team_lku_types.key]
  business_role_key string [ref: > user_business_role_lku_types.key]
  is_deleted boolean
  created_at timestamp
  updated_at timestamp
}

// ============================================================================
// CONTACTS & RELATIONSHIPS
// ============================================================================

Table contacts {
  id bigint [pk]
  org_id bigint [not null, ref: > orgs.id]
  first_name string
  last_name string
  birth_date date
  middle_name string
  name_suffix string
  full_name string
  preferred_name string
  death_date date
  ssn_last4 string
  company_name string
  website string
  npi string
  tin string
  email string
  email_alternative string
  note_human string
  note_ai string
  note_system string
  pronouns string
  ext jsonb
  type_key string [ref: > contact_lku_types.key]
  sex_key string [ref: > contacts_lku_sexes.key]
  language_primary_key string [ref: > contacts_lku_languages.key]
  language_secondary_key string [ref: > contacts_lku_languages.key]
  ethnicity_key string [ref: > contacts_lku_ethnicities.key]
  race_key string [ref: > contacts_lku_races.key]
  timezone_override_key string [ref: > ref_timezones.key]
  deleted_at timestamp
  is_deleted boolean
  deleted_by_id bigint [ref: > users.id]
  created_by_id bigint [ref: > users.id]
  updated_by_id bigint [ref: > users.id]
  created_at timestamp
  updated_at timestamp
}

Table contact_lku_types {
  key string [pk]
  org_id bigint [pk, ref: > orgs.id]
  name string
  is_human boolean
  created_at timestamp
  updated_at timestamp
}

Table contacts_lku_sexes {
  key string [pk]
  org_id bigint [pk, ref: > orgs.id]
  name string
  created_at timestamp
  updated_at timestamp
}

Table contacts_lku_languages {
  key string [pk]
  org_id bigint [pk, ref: > orgs.id]
  name string
  created_at timestamp
  updated_at timestamp
}

Table contacts_lku_ethnicities {
  key string [pk]
  org_id bigint [pk, ref: > orgs.id]
  name string
  created_at timestamp
  updated_at timestamp
}

Table contacts_lku_races {
  key string [pk]
  org_id bigint [pk, ref: > orgs.id]
  name string
  created_at timestamp
  updated_at timestamp
}

Table contact_addresses {
  id bigint [pk]
  org_id bigint [not null, ref: > orgs.id]
  contact_id bigint [not null, ref: > contacts.id]
  line_1 string
  line_2 string
  city string
  state string
  zip5 string
  is_primary boolean
  type_key string [ref: > contact_address_lku_types.key]
  is_deleted boolean
  created_by_id bigint [ref: > users.id]
  updated_by_id bigint [ref: > users.id]
  created_at timestamp
  updated_at timestamp
}

Table contact_address_lku_types {
  key string [pk]
  org_id bigint [pk, ref: > orgs.id]
