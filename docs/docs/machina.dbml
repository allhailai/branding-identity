Table contact_phone_lku_verification_statuses {
  key string [pk]
  org_id bigint [pk, ref: > orgs.id]
  name string
  created_at timestamp
  updated_at timestamp
}

Table contact_events {
  id bigint [pk]
  org_id bigint [not null, ref: > orgs.id]
  contact_id bigint [not null, ref: > contacts.id]
  event_at timestamp
  type_key string [ref: > contact_event_lku_types.key]
  status_key string [ref: > contact_event_lku_statuses.key]
  created_by_id bigint [ref: > users.id]
  updated_by_id bigint [ref: > users.id]
  created_at timestamp
  updated_at timestamp
}

Table contact_event_lku_types {
  key string [pk]
  org_id bigint [pk, ref: > orgs.id]
