---
---

<section class="solution" id="solution">
  <div class="solution-inner">
    <div class="reveal">
      <div class="section-label">What You Get</div>
      <h2>
        Meet Machina — everything a patient-facing company needs to operate.
        Out of the box.
      </h2>
      <p class="solution-subtitle">
        Our Core SDK handles 90% of what all patient-facing companies need. You
        focus on building the 10% that makes your care model unique.
      </p>
    </div>
    <div class="solution-columns">
      <div class="ninety-ten reveal">
        <div class="arch-diagram">
          <!-- Client layer: 10% -->
          <div class="arch-layer arch-layer-client">
            <div class="arch-layer-label">
              <span class="arch-pct">10%</span>
              <span class="arch-layer-tag">Your Layer</span>
            </div>
            <div class="arch-title">You build this.</div>
            <div class="arch-desc">
              Care protocols, workforce configurations, and patient experiences
              that define your brand — the last mile that makes you different.
            </div>
          </div>
          <!-- Machina layer: 90% -->
          <div class="arch-layer arch-layer-platform">
            <div class="arch-layer-label">
              <span class="arch-pct">90%</span>
              <span class="arch-layer-tag">Machina Core</span>
            </div>
            <div class="arch-title">We handle this.</div>
            <div class="arch-desc">
              Workflows, tasks, queues, PSJ, compliance posture, AI agents, and
              secure infrastructure — all in the Core SDK, deployed into your
              AWS account. Yours to own and operate.
            </div>
          </div>
          <!-- Infrastructure layer -->
          <div class="arch-layer arch-layer-infra">
            <div class="arch-layer-label">
              <span class="arch-layer-tag">Infrastructure</span>
            </div>
            <div class="arch-infra-badges">
              <span class="arch-infra-badge">AWS</span>
              <span class="arch-infra-badge">HIPAA</span>
              <span class="arch-infra-badge">SOC 2</span>
              <span class="arch-infra-badge">Encryption</span>
              <span class="arch-infra-badge">Audit Trails</span>
            </div>
          </div>
        </div>
      </div>
      <div class="solution-features reveal">
        <div class="feature-item">
          <div class="feature-icon">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><rect x="4" y="4" width="16" height="16" rx="2"></rect><rect
                x="9"
                y="9"
                width="6"
                height="6"></rect><line x1="9" y1="1" x2="9" y2="4"
              ></line><line x1="15" y1="1" x2="15" y2="4"></line><line
                x1="9"
                y1="20"
                x2="9"
                y2="23"></line><line x1="15" y1="20" x2="15" y2="23"
              ></line><line x1="20" y1="9" x2="23" y2="9"></line><line
                x1="20"
                y1="14"
                x2="23"
                y2="14"></line><line x1="1" y1="9" x2="4" y2="9"></line><line
                x1="1"
                y1="14"
                x2="4"
                y2="14"></line></svg
            >
          </div>
          <div>
            <h4>Agentic AI Workforce</h4>
            <p>
              Autonomous agents that run your business processes — scheduling,
              routing, intake, follow-ups — the same operations your competitors
              are still staffing manually. Your human team focuses on care. Your
              AI team handles the rest.
            </p>
          </div>
        </div>
        <div class="feature-item">
          <div class="feature-icon">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"
              ></polygon></svg
            >
          </div>
          <div>
            <h4>Operational on Day One</h4>
            <p>
              Go live with the operational maturity most healthcare companies
              take years to reach. No engineering team required.
            </p>
          </div>
        </div>
        <div class="feature-item">
          <div class="feature-icon">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
              ></path><polyline points="9 12 11 14 15 10"></polyline></svg
            >
          </div>
          <div>
            <h4>Compliant Infrastructure</h4>
            <p>
              HIPAA and SOC 2 compliant AWS environment. Encryption, logging,
              access controls, BAAs, and audit trails — configured from day one.
            </p>
          </div>
        </div>
        <div class="feature-item">
          <div class="feature-icon">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><polygon points="12 2 2 7 12 12 22 7 12 2"></polygon><polyline
                points="2 17 12 22 22 17"></polyline><polyline
                points="2 12 12 17 22 12"></polyline></svg
            >
          </div>
          <div>
            <h4>Core SDK</h4>
            <p>
              Workflows, tasks, queues, and Patient Status Journey — the
              operational backbone every healthcare company needs, codified and
              ready.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .solution {
    padding: 8rem 4rem;
    background: linear-gradient(
      180deg,
      var(--deep) 0%,
      rgba(62, 232, 181, 0.03) 50%,
      var(--deep) 100%
    );
  }

  .solution-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .solution h2 {
    font-family: "DM Serif Display", serif;
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--white);
    line-height: 1.15;
    max-width: 800px;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }

  .solution-subtitle {
    font-size: 1.15rem;
    color: var(--text-dim);
    max-width: 650px;
    line-height: 1.7;
    margin-bottom: 4rem;
    font-weight: 300;
  }

  .solution-columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .ninety-ten {
    position: relative;
  }

  /* 90/10 ARCHITECTURE DIAGRAM */
  .arch-diagram {
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid rgba(62, 232, 181, 0.2);
    box-shadow: 0 0 40px rgba(62, 232, 181, 0.06);
  }

  .arch-layer {
    padding: 1.8rem 2rem;
    position: relative;
  }

  .arch-layer-client {
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.04),
      rgba(255, 255, 255, 0.02)
    );
    border-bottom: 1px solid rgba(62, 232, 181, 0.15);
  }
  .arch-layer-platform {
    background: linear-gradient(
      135deg,
      rgba(62, 232, 181, 0.1),
      rgba(62, 232, 181, 0.05)
    );
    border-bottom: 1px solid rgba(62, 232, 181, 0.2);
    padding: 2.2rem 2rem;
  }
  .arch-layer-infra {
    background: linear-gradient(
      135deg,
      rgba(10, 22, 40, 0.9),
      rgba(17, 29, 51, 0.9)
    );
  }

  .arch-layer-label {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .arch-pct {
    font-family: "DM Serif Display", serif;
    font-size: 2rem;
    line-height: 1;
    font-weight: 600;
  }
  .arch-layer-client .arch-pct {
    color: var(--warm-accent);
  }
  .arch-layer-platform .arch-pct {
    color: var(--accent);
  }

  .arch-layer-tag {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 600;
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
  }
  .arch-layer-client .arch-layer-tag {
    background: var(--warm-accent-dim);
    color: var(--warm-accent);
    border: 1px solid rgba(232, 168, 76, 0.25);
  }
  .arch-layer-platform .arch-layer-tag {
    background: var(--accent-dim);
    color: var(--accent);
    border: 1px solid rgba(62, 232, 181, 0.25);
  }
  .arch-layer-infra .arch-layer-tag {
    background: rgba(255, 255, 255, 0.06);
    color: var(--text-dim);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .arch-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--white);
    margin-bottom: 0.4rem;
  }
  .arch-desc {
    font-size: 0.85rem;
    color: var(--text-dim);
    line-height: 1.55;
    font-weight: 300;
  }

  .arch-infra-badges {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
    margin-top: 0.6rem;
  }
  .arch-infra-badge {
    font-size: 0.72rem;
    color: var(--text-dim);
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 4px;
    padding: 0.2rem 0.55rem;
    letter-spacing: 0.04em;
    font-weight: 500;
  }

  .solution-features {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .feature-item {
    display: flex;
    gap: 1.2rem;
    align-items: flex-start;
  }

  .feature-icon {
    width: 48px;
    height: 48px;
    min-width: 48px;
    border-radius: 12px;
    background: var(--accent-dim);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
  }
  .feature-icon svg {
    width: 22px;
    height: 22px;
  }

  .feature-item h4 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.3rem;
    color: var(--white);
  }

  .feature-item p {
    font-size: 0.9rem;
    color: var(--text-dim);
    line-height: 1.55;
    font-weight: 300;
  }

  @media (max-width: 968px) {
    .solution {
      padding: 5rem 2rem;
    }
    .solution-columns {
      grid-template-columns: 1fr;
    }
  }
</style>
