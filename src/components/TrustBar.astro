---
---

<div class="trust-bar">
  <p>Built for compliance-first healthcare companies</p>
  <div class="trust-logos">
    <div class="trust-badge">
      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><polyline
          points="9 12 11 14 15 10"></polyline></svg
      >
       HIPAA Compliant
    </div>
    <div class="trust-badge">
      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><polyline
          points="9 12 11 14 15 10"></polyline></svg
      >
       SOC 2 Type II
    </div>
    <div class="trust-badge">
      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path
          d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg
      >
       256-bit Encryption
    </div>
    <div class="trust-badge">
      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"
        ></path><polyline points="14 2 14 8 20 8"></polyline><polyline
          points="9 15 11 17 15 13"></polyline></svg
      >
       BAA Available
    </div>
    <div class="trust-badge trust-badge-aws">
      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"></path></svg
      >
       Built on AWS
    </div>
  </div>
</div>

<style>
  .trust-bar {
    padding: 3rem 4rem;
    text-align: center;
    border-top: 1px solid rgba(255, 255, 255, 0.04);
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
  }

  .trust-bar p {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--text-dim);
    margin-bottom: 1.5rem;
    font-weight: 500;
  }

  .trust-logos {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1.2rem;
    flex-wrap: wrap;
  }

  .trust-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.7rem 1.3rem;
    border: 1px solid rgba(62, 232, 181, 0.25);
    border-radius: 8px;
    background: rgba(62, 232, 181, 0.05);
    backdrop-filter: blur(8px);
    font-size: 0.82rem;
    color: var(--accent);
    font-weight: 600;
    letter-spacing: 0.06em;
    transition: all 0.3s;
  }
  .trust-badge:hover {
    border-color: rgba(62, 232, 181, 0.5);
    background: rgba(62, 232, 181, 0.1);
    box-shadow: 0 0 18px rgba(62, 232, 181, 0.18);
    transform: translateY(-1px);
  }
  .trust-badge svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .trust-badge-aws {
    border-color: rgba(255, 153, 0, 0.3);
    background: rgba(255, 153, 0, 0.05);
    color: #ff9900;
  }
  .trust-badge-aws:hover {
    border-color: rgba(255, 153, 0, 0.55);
    background: rgba(255, 153, 0, 0.1);
    box-shadow: 0 0 18px rgba(255, 153, 0, 0.18);
  }

  @media (max-width: 600px) {
    .trust-logos {
      gap: 0.8rem;
    }
    .trust-badge {
      padding: 0.6rem 1rem;
      font-size: 0.75rem;
    }
  }
</style>
