---
---

<section class="exec-section exec-section-auto exec-scoreboard" id="exec-scoreboard">
  <div class="scoreboard-bg">
    <img src="/branding-identity/backgrounds/grid.png" alt="" class="scoreboard-bg-img" />
    <div class="scoreboard-overlay"></div>
  </div>

  <div class="scoreboard-content">
    <div class="exec-inner">
      <div class="exec-label">The Numbers That Matter</div>
      <div class="exec-big">These are the metrics your agentic workforce delivers — the ones you bring to your next <em class="hl-gold">board meeting.</em></div>

      <div class="score-grid">
        <div class="score-card exec-reveal">
          <div class="score-number">89%</div>
          <div class="score-title">Tasks AI-Completed</div>
          <div class="score-desc">Routine operational tasks completed by agents without human intervention.</div>
        </div>
        <div class="score-card exec-reveal">
          <div class="score-number">3.1%</div>
          <div class="score-title">Patient Drop-off</div>
          <div class="score-desc">Down from 18% baseline. Communications agent catches every touchpoint.</div>
        </div>
        <div class="score-card exec-reveal">
          <div class="score-number">1.2d</div>
          <div class="score-title">Avg Time-to-Intake</div>
          <div class="score-desc">Down from 4.8 days. Queue agent eliminates intake bottlenecks.</div>
        </div>
        <div class="score-card exec-reveal">
          <div class="score-number">67%</div>
          <div class="score-title">OpEx Reduction</div>
          <div class="score-desc">Coordination labor absorbed by agents. Headcount flat while volume scales.</div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .exec-scoreboard {
    position: relative;
    flex-direction: column;
    padding: 120px 40px;
  }

  .scoreboard-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .scoreboard-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .scoreboard-overlay {
    position: absolute;
    inset: 0;
    background: rgba(18, 31, 54, 0.88);
  }

  .scoreboard-content {
    position: relative;
    z-index: 1;
  }

  .score-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin: 48px 0 0;
  }

  .score-card {
    background: var(--navy);
    border-radius: 16px;
    padding: 32px 24px;
    border: 1px solid rgba(255,255,255,0.04);
    text-align: center;
    position: relative;
    overflow: hidden;
    transition: transform 0.3s, border-color 0.3s;
  }

  .score-card:hover {
    transform: translateY(-4px);
    border-color: rgba(240,180,41,0.15);
  }

  .score-card::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 20%;
    right: 20%;
    height: 2px;
    border-radius: 2px;
  }

  .score-card:nth-child(1)::after { background: var(--gold); }
  .score-card:nth-child(2)::after { background: var(--green); }
  .score-card:nth-child(3)::after { background: var(--teal); }
  .score-card:nth-child(4)::after { background: var(--coral); }

  .score-number {
    font-family: var(--font-mono);
    font-size: 2.8rem;
    font-weight: 500;
    margin-bottom: 4px;
  }

  .score-card:nth-child(1) .score-number { color: var(--gold); }
  .score-card:nth-child(2) .score-number { color: var(--green); }
  .score-card:nth-child(3) .score-number { color: var(--teal); }
  .score-card:nth-child(4) .score-number { color: var(--coral); }

  .score-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--white);
    margin-bottom: 6px;
  }

  .score-desc {
    font-size: 0.82rem;
    color: var(--gray-500);
    line-height: 1.5;
  }

  @media (max-width: 900px) {
    .score-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .exec-scoreboard {
      padding: 80px 24px;
    }
  }

  @media (max-width: 600px) {
    .score-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
