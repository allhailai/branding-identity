---
import OverviewLayout from "../../../layouts/OverviewLayout.astro";
import FeatureDetail from "../../../components/overview/FeatureDetail.astro";
import { features } from "../../../components/overview/feature-data.js";

export function getStaticPaths() {
  return features.map(function(feature, index) {
    const prevFeature = features[index - 1] ?? null;
    const nextFeature = features[index + 1] ?? null;
    return {
      params: { slug: feature.slug },
      props: { feature, prevFeature, nextFeature },
    };
  });
}

const { feature, prevFeature, nextFeature } = Astro.props;
---

<OverviewLayout title={`Machina — ${feature.name}`} activeSlug={feature.slug}>
  <FeatureDetail
    name={feature.name}
    type={feature.type}
    badge={feature.badge}
    description={feature.description}
    screenshot={feature.screenshot}
    video={feature.video}
    prevFeature={prevFeature}
    nextFeature={nextFeature}
  />
</OverviewLayout>
